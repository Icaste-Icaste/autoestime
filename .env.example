# ── Anthropic (obligatoire) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── API Décodage plaque (optionnel — simulation Claude si absent) ─────
# Choisir un provider : datadecision | autobiz | sivplaque | infosimmat | generic | claude
PLATE_API_PROVIDER=claude

# Si provider != claude, renseigner :
PLATE_API_KEY=
# URL de base de l'API (sans la plaque)
# Ex DataDecision : https://api.datadecision.fr/v1
# Ex SivPlaque    : https://api.sivplaque.fr/v1
# Ex générique    : https://votre-provider.fr/api/plaque
PLATE_API_URL=

# ── Apify (optionnel — cotes LeBonCoin temps réel) ───────────────────
# Token Apify : https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ── Serveur ──────────────────────────────────────────────────────────
PORT=3000
